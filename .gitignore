cmake-build-*/
build/
out/

# 루트에서 직접 빌드할 경우 생기는 CMake 산출물
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ===== 컴파일 결과물 =====
*.o
*.obj
*.exe
*.out
*.app
*.dSYM/
a.out

# ===== macOS =====
.DS_Store

# ===== 로그/임시 =====
*.log
*.tmp

# ===== 입력 데이터 (용량 크므로 git 제외, 직접 다운) =====
*.fasta

